    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#locatedInCity -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#locatedInCity">
