        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TypicalFood"/>
        <rdfs:comment xml:lang="en">A drink, alcoholic or non-alcoholic.</rdfs:comment>
        <rdfs:comment xml:lang="es">Bebida, alcohólica o no alcohólica.</rdfs:comment>
        <rdfs:label xml:lang="es">Bebida</rdfs:label>
        <rdfs:label xml:lang="en">Beverage</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Bus -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Bus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#LandTransport"/>
        <rdfs:comment xml:lang="en">A road vehicle for passenger transport over fixed routes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vehículo terrestre para transporte de pasajeros en rutas fijas.</rdfs:comment>
        <rdfs:label xml:lang="en">Bus</rdfs:label>
        <rdfs:label xml:lang="es">Bus</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Camping -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Camping">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#MountainSport"/>
        <rdfs:comment xml:lang="es">Estancia nocturna al aire libre en tiendas o refugios.</rdfs:comment>
        <rdfs:comment xml:lang="en">Outdoor overnight stay in tents or shelters.</rdfs:comment>
        <rdfs:label xml:lang="en">Camping</rdfs:label>
        <rdfs:label xml:lang="es">Camping</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#City -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#City">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Location"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Country"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Island"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Province"/>
        <rdfs:comment xml:lang="en">An urban settlement; municipality or regency.</rdfs:comment>
        <rdfs:comment xml:lang="es">Asentamiento urbano; municipio o regencia.</rdfs:comment>
        <rdfs:label xml:lang="en">City</rdfs:label>
        <rdfs:label xml:lang="es">Ciudad</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CityLifeAttraction -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CityLifeAttraction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TouristAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CulturalAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#NaturalAttractions"/>
        <rdfs:comment xml:lang="es">Lugares de entretenimiento urbano como bares, discotecas, pubs y espectáculos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Urban entertainment venues such as bars, clubs, pubs, and shows.</rdfs:comment>
        <rdfs:label xml:lang="en">City Life Attraction</rdfs:label>
        <rdfs:label xml:lang="es">Vida nocturna</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Climbing -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Climbing">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#MountainSport"/>
        <rdfs:comment xml:lang="es">Escalar rocas, montañas o paredes por deporte.</rdfs:comment>
        <rdfs:comment xml:lang="en">Scaling rocks, mountains or walls for sport.</rdfs:comment>
        <rdfs:label xml:lang="en">Climbing</rdfs:label>
        <rdfs:label xml:lang="es">Escalada</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Club -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Club">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CityLifeAttraction"/>
        <rdfs:comment xml:lang="en">A nightclub featuring music and dancing.</rdfs:comment>
        <rdfs:comment xml:lang="es">Discoteca con música y baile.</rdfs:comment>
        <rdfs:label xml:lang="en">Club</rdfs:label>
        <rdfs:label xml:lang="es">Discoteca</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Condiment -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Condiment">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TypicalFood"/>
        <rdfs:comment xml:lang="en">A sauce or seasoning used to flavour food.</rdfs:comment>
        <rdfs:comment xml:lang="es">Salsa o condimento usado para sazonar la comida.</rdfs:comment>
        <rdfs:label xml:lang="en">Condiment</rdfs:label>
        <rdfs:label xml:lang="es">Condimento</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Country -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Country">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Location"/>
        <rdfs:comment xml:lang="en">A sovereign nation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Nación soberana.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
        <rdfs:label xml:lang="es">País</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CulturalAttraction -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CulturalAttraction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TouristAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#NaturalAttractions"/>
        <rdfs:comment xml:lang="en">Sites of cultural or historical significance such as museums, temples, ceremonies.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sitios de relevancia cultural o histórica como museos, templos o ceremonias.</rdfs:comment>
        <rdfs:label xml:lang="es">Atracción Cultural</rdfs:label>
        <rdfs:label xml:lang="en">Cultural Attraction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Dessert -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Dessert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TypicalFood"/>
        <rdfs:comment xml:lang="en">A sweet course eaten at the end of a meal.</rdfs:comment>
        <rdfs:comment xml:lang="es">Plato dulce que se toma al final de una comida.</rdfs:comment>
        <rdfs:label xml:lang="en">Dessert</rdfs:label>
        <rdfs:label xml:lang="es">Postre</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Diving -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Diving">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterSport"/>
        <rdfs:comment xml:lang="es">Deporte de natación submarina, con o sin equipo de buceo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Underwater swimming sport, with or without scuba gear.</rdfs:comment>
        <rdfs:label xml:lang="es">Buceo</rdfs:label>
        <rdfs:label xml:lang="en">Diving</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Establishments -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Establishments">
        <rdfs:comment xml:lang="en">Commercial or public venues where services are offered (markets, restaurants, vendors).</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugares comerciales o públicos donde se ofrecen servicios (mercados, restaurantes, vendedores).</rdfs:comment>
        <rdfs:label xml:lang="es">Establecimiento</rdfs:label>
        <rdfs:label xml:lang="en">Establishment</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Events -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Events">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TouristAttraction"/>
        <rdfs:comment xml:lang="es">Acontecimientos programados como festivales, ceremonias o espectáculos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Scheduled occurrences such as festivals, ceremonies or shows.</rdfs:comment>
        <rdfs:label xml:lang="es">Eventos</rdfs:label>
        <rdfs:label xml:lang="en">Events</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Family -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Family">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Group"/>
        <rdfs:comment xml:lang="en">A group of related persons travelling together.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grupo de personas emparentadas que viajan juntas.</rdfs:comment>
        <rdfs:label xml:lang="es">Familia</rdfs:label>
        <rdfs:label xml:lang="en">Family</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Ferry -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Ferry">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterTransport"/>
        <rdfs:comment xml:lang="en">A boat carrying passengers and vehicles across water.</rdfs:comment>
        <rdfs:comment xml:lang="es">Embarcación que transporta pasajeros y vehículos por el agua.</rdfs:comment>
        <rdfs:label xml:lang="en">Ferry</rdfs:label>
        <rdfs:label xml:lang="es">Ferry</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Festival -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Festival">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Events"/>
        <rdfs:comment xml:lang="en">A periodic public celebration, often cultural or religious.</rdfs:comment>
        <rdfs:comment xml:lang="es">Celebración pública periódica, frecuentemente cultural o religiosa.</rdfs:comment>
        <rdfs:label xml:lang="en">Festival</rdfs:label>
        <rdfs:label xml:lang="es">Festival</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Group -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Group">
        <rdfs:comment xml:lang="en">A travel party of multiple persons.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grupo de viaje compuesto por varias personas.</rdfs:comment>
        <rdfs:label xml:lang="en">Group</rdfs:label>
        <rdfs:label xml:lang="es">Grupo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Guesthouse -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Guesthouse">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Accommodation"/>
        <rdfs:comment xml:lang="en">A small lodging facility, often family-run.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento pequeño de alojamiento, frecuentemente familiar.</rdfs:comment>
        <rdfs:label xml:lang="es">Casa de huéspedes</rdfs:label>
        <rdfs:label xml:lang="en">Guesthouse</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Hiking -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Hiking">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#MountainSport"/>
        <rdfs:comment xml:lang="es">Caminar por senderos, generalmente en la naturaleza.</rdfs:comment>
        <rdfs:comment xml:lang="en">Walking on trails, usually in nature.</rdfs:comment>
        <rdfs:label xml:lang="en">Hiking</rdfs:label>
        <rdfs:label xml:lang="es">Senderismo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Hindus -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Hindus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Group"/>
        <rdfs:comment xml:lang="es">Personas que practican la religión hindú.</rdfs:comment>
        <rdfs:comment xml:lang="en">Persons practicing the Hindu religion.</rdfs:comment>
        <rdfs:label xml:lang="en">Hindus</rdfs:label>
        <rdfs:label xml:lang="es">Hindúes</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Hostel -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Hostel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Accommodation"/>
        <rdfs:comment xml:lang="es">Alojamiento compartido económico popular entre mochileros.</rdfs:comment>
        <rdfs:comment xml:lang="en">Budget shared lodging popular with backpackers.</rdfs:comment>
        <rdfs:label xml:lang="es">Hostal</rdfs:label>
        <rdfs:label xml:lang="en">Hostel</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Hotel -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Hotel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Accommodation"/>
        <rdfs:comment xml:lang="en">A commercial lodging establishment offering rooms and services.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento comercial de alojamiento que ofrece habitaciones y servicios.</rdfs:comment>
        <rdfs:label xml:lang="en">Hotel</rdfs:label>
        <rdfs:label xml:lang="es">Hotel</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Household -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Household">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Establishments"/>
        <rdfs:comment xml:lang="en">A family or co-resident unit travelling together.</rdfs:comment>
        <rdfs:comment xml:lang="es">Unidad familiar o de convivientes que viaja junta.</rdfs:comment>
        <rdfs:label xml:lang="es">Hogar</rdfs:label>
        <rdfs:label xml:lang="en">Household</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Ingredient -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Ingredient">
        <rdfs:comment xml:lang="en">A component used in preparing a dish.</rdfs:comment>
        <rdfs:comment xml:lang="es">Componente utilizado para preparar un plato.</rdfs:comment>
        <rdfs:label xml:lang="en">Ingredient</rdfs:label>
        <rdfs:label xml:lang="es">Ingrediente</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Island -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Island">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Location"/>
        <rdfs:comment xml:lang="en">A landmass surrounded by water.</rdfs:comment>
        <rdfs:comment xml:lang="es">Masa de tierra rodeada de agua.</rdfs:comment>
        <rdfs:label xml:lang="es">Isla</rdfs:label>
        <rdfs:label xml:lang="en">Island</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Kayaking -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Kayaking">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterSport"/>
        <rdfs:comment xml:lang="en">Paddling a small narrow boat through water.</rdfs:comment>
        <rdfs:comment xml:lang="es">Remar en una pequeña embarcación estrecha por el agua.</rdfs:comment>
        <rdfs:label xml:lang="es">Kayak</rdfs:label>
        <rdfs:label xml:lang="en">Kayaking</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#LandTransport -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#LandTransport">
