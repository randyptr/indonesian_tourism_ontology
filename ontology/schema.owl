        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#hasVegetarianFood -->

