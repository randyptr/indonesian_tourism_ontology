        <rdfs:comment xml:lang="es">Zona costera junto al mar u océano adecuada para el turismo.</rdfs:comment>
        <rdfs:label xml:lang="en">Beach</rdfs:label>
        <rdfs:label xml:lang="es">Playa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Beverage -->

