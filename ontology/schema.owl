        <rdfs:comment xml:lang="en">A venue primarily serving alcoholic drinks.</rdfs:comment>
        <rdfs:comment xml:lang="es">Local que sirve principalmente bebidas alcohólicas.</rdfs:comment>
        <rdfs:label xml:lang="en">Bar</rdfs:label>
        <rdfs:label xml:lang="es">Bar</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Beach -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Beach">
