        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterTransport"/>
        <rdfs:comment xml:lang="en">Transport by road (buses, terminals, taxis).</rdfs:comment>
        <rdfs:comment xml:lang="es">Transporte por carretera (autobuses, terminales, taxis).</rdfs:comment>
        <rdfs:label xml:lang="en">LandTransport</rdfs:label>
        <rdfs:label xml:lang="es">TransporteTerrestre</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Locals -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Locals">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Group"/>
        <rdfs:comment xml:lang="es">Residentes nativos del destino.</rdfs:comment>
        <rdfs:comment xml:lang="en">Residents native to the destination.</rdfs:comment>
        <rdfs:label xml:lang="es">Local</rdfs:label>
        <rdfs:label xml:lang="en">Locals</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Location -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Location">
        <rdfs:comment xml:lang="en">A geographic entity (country, province, island, or city).</rdfs:comment>
        <rdfs:comment xml:lang="es">Entidad geográfica (país, provincia, isla o ciudad).</rdfs:comment>
        <rdfs:label xml:lang="es">Localización</rdfs:label>
        <rdfs:label xml:lang="en">Location</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#MainDish -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#MainDish">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TypicalFood"/>
        <rdfs:comment xml:lang="es">Plato principal de una comida.</rdfs:comment>
        <rdfs:comment xml:lang="en">The principal course of a meal.</rdfs:comment>
        <rdfs:label xml:lang="en">Main Dish</rdfs:label>
        <rdfs:label xml:lang="es">Plato Principal</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Man -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Man">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Adult"/>
        <rdfs:comment xml:lang="en">An adult male person.</rdfs:comment>
        <rdfs:comment xml:lang="es">Persona adulta de género masculino.</rdfs:comment>
        <rdfs:label xml:lang="es">Hombre</rdfs:label>
        <rdfs:label xml:lang="en">Man</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#MountainSport -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#MountainSport">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Activities"/>
        <rdfs:comment xml:lang="es">Actividades recreativas en terreno montañoso (senderismo, escalada).</rdfs:comment>
        <rdfs:comment xml:lang="en">Recreational activities in mountainous terrain (hiking, climbing).</rdfs:comment>
        <rdfs:label xml:lang="es">Deporte de montaña</rdfs:label>
        <rdfs:label xml:lang="en">Mountain Sport</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Museum -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Museum">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CulturalAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Temple"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalDance"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalHouse"/>
        <rdfs:comment xml:lang="en">A building exhibiting cultural, historical or artistic collections.</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio que exhibe colecciones culturales, históricas o artísticas.</rdfs:comment>
        <rdfs:label xml:lang="es">Museo</rdfs:label>
        <rdfs:label xml:lang="en">Museum</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#NaturalAttractions -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#NaturalAttractions">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TouristAttraction"/>
        <rdfs:comment xml:lang="en">Natural sites including beaches, volcanoes, parks, and other outdoor landmarks.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sitios naturales que incluyen playas, volcanes, parques y otros lugares al aire libre.</rdfs:comment>
        <rdfs:label xml:lang="es">Atracciones Naturales</rdfs:label>
        <rdfs:label xml:lang="en">Natural Attractions</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Organisation -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Organisation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Group"/>
        <rdfs:comment xml:lang="en">A formal entity such as a tourism authority, agency, or NGO.</rdfs:comment>
        <rdfs:comment xml:lang="es">Entidad formal como una autoridad de turismo, agencia u ONG.</rdfs:comment>
        <rdfs:label xml:lang="en">Organisation</rdfs:label>
        <rdfs:label xml:lang="es">Organización</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Park -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Park">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#NaturalAttractions"/>
        <rdfs:comment xml:lang="en">A protected natural area such as a national or botanic park.</rdfs:comment>
        <rdfs:comment xml:lang="es">Área natural protegida como un parque nacional o botánico.</rdfs:comment>
        <rdfs:label xml:lang="en">Park</rdfs:label>
        <rdfs:label xml:lang="es">Parque</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Person -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Person">
        <rdfs:comment xml:lang="en">A human agent participating in tourism — tourist, guide, local, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Agente humano que participa en el turismo: turista, guía, local, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Person</rdfs:label>
        <rdfs:label xml:lang="es">Persona</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Plane -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Plane">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#AirTransport"/>
        <rdfs:comment xml:lang="es">Aeronave utilizada para viajes comerciales o chárter.</rdfs:comment>
        <rdfs:comment xml:lang="en">An aircraft used for commercial or chartered travel.</rdfs:comment>
        <rdfs:label xml:lang="es">Avión</rdfs:label>
        <rdfs:label xml:lang="en">Plane</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Port -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Port">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterTransport"/>
        <rdfs:comment xml:lang="en">A coastal facility for ships and ferries.</rdfs:comment>
        <rdfs:comment xml:lang="es">Instalación costera para barcos y ferries.</rdfs:comment>
        <rdfs:label xml:lang="en">Port</rdfs:label>
        <rdfs:label xml:lang="es">Puerto</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Province -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Province">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Location"/>
        <rdfs:comment xml:lang="en">A first-level administrative subdivision of a country.</rdfs:comment>
        <rdfs:comment xml:lang="es">Subdivisión administrativa de primer nivel de un país.</rdfs:comment>
        <rdfs:label xml:lang="en">Province</rdfs:label>
        <rdfs:label xml:lang="es">Provincia</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Pub -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Pub">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CityLifeAttraction"/>
        <rdfs:comment xml:lang="en">A casual drinking establishment, often serving food.</rdfs:comment>
        <rdfs:comment xml:lang="es">Establecimiento informal de bebidas, frecuentemente con comida.</rdfs:comment>
        <rdfs:label xml:lang="en">Pub</rdfs:label>
        <rdfs:label xml:lang="es">Pub</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#ReligiousCeremony -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#ReligiousCeremony">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Events"/>
        <rdfs:comment xml:lang="en">A ritual performance with religious meaning.</rdfs:comment>
        <rdfs:comment xml:lang="es">Acto ritual con significado religioso.</rdfs:comment>
        <rdfs:label xml:lang="es">Ceremonia Religiosa</rdfs:label>
        <rdfs:label xml:lang="en">Religious Ceremony</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Resort -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Resort">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Accommodation"/>
        <rdfs:comment xml:lang="en">A vacation-oriented lodging with extensive amenities.</rdfs:comment>
        <rdfs:comment xml:lang="es">Alojamiento orientado a vacaciones con amplios servicios.</rdfs:comment>
        <rdfs:label xml:lang="en">Resort</rdfs:label>
        <rdfs:label xml:lang="es">Resort</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Restaurant -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Restaurant">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Establishments"/>
        <rdfs:comment xml:lang="en">A venue serving prepared food and drinks to customers.</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugar que sirve alimentos y bebidas preparados a los clientes.</rdfs:comment>
        <rdfs:label xml:lang="en">Restaurant</rdfs:label>
        <rdfs:label xml:lang="es">Restaurante</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Sailing -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Sailing">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterSport"/>
        <rdfs:comment xml:lang="en">Travelling on water using wind-powered boats.</rdfs:comment>
        <rdfs:comment xml:lang="es">Viajar sobre el agua en embarcaciones propulsadas por el viento.</rdfs:comment>
        <rdfs:label xml:lang="en">Sailing</rdfs:label>
        <rdfs:label xml:lang="es">Vela</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Show -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Show">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Events"/>
        <rdfs:comment xml:lang="en">A staged performance such as a play, concert, or cultural exhibition.</rdfs:comment>
        <rdfs:comment xml:lang="es">Representación en escena como una obra, concierto o exhibición cultural.</rdfs:comment>
        <rdfs:label xml:lang="es">Espectáculo</rdfs:label>
        <rdfs:label xml:lang="en">Show</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#SideDish -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#SideDish">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TypicalFood"/>
        <rdfs:comment xml:lang="en">A complementary dish accompanying a main course.</rdfs:comment>
        <rdfs:comment xml:lang="es">Plato complementario que acompaña al principal.</rdfs:comment>
        <rdfs:label xml:lang="es">Guarnición</rdfs:label>
        <rdfs:label xml:lang="en">Side Dish</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Snorkeling -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Snorkeling">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterSport"/>
        <rdfs:comment xml:lang="es">Nadar cerca de la superficie respirando con un tubo snorkel.</rdfs:comment>
        <rdfs:comment xml:lang="en">Swimming near the surface while breathing through a snorkel tube.</rdfs:comment>
        <rdfs:label xml:lang="es">Esnórquel</rdfs:label>
        <rdfs:label xml:lang="en">Snorkeling</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Soup -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Soup">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TypicalFood"/>
        <rdfs:comment xml:lang="en">A liquid dish, often served warm as a starter or main.</rdfs:comment>
        <rdfs:comment xml:lang="es">Plato líquido, frecuentemente servido caliente como entrante o principal.</rdfs:comment>
        <rdfs:label xml:lang="es">Sopa</rdfs:label>
        <rdfs:label xml:lang="en">Soup</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#StreetVendor -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#StreetVendor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Establishments"/>
        <rdfs:comment xml:lang="en">A small informal vendor or warung selling food in the street.</rdfs:comment>
        <rdfs:comment xml:lang="es">Pequeño vendedor informal o warung que vende comida en la calle.</rdfs:comment>
        <rdfs:label xml:lang="en">Street Vendor</rdfs:label>
        <rdfs:label xml:lang="es">Vendedor Callejero</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Surfing -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Surfing">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterSport"/>
        <rdfs:comment xml:lang="es">Deslizarse sobre las olas del mar en una tabla.</rdfs:comment>
        <rdfs:comment xml:lang="en">Riding ocean waves on a board.</rdfs:comment>
        <rdfs:label xml:lang="es">Surf</rdfs:label>
        <rdfs:label xml:lang="en">Surfing</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Temple -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Temple">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CulturalAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalDance"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalHouse"/>
        <rdfs:comment xml:lang="en">A religious building used for worship or ritual.</rdfs:comment>
        <rdfs:comment xml:lang="es">Edificio religioso usado para el culto o el ritual.</rdfs:comment>
        <rdfs:label xml:lang="en">Temple</rdfs:label>
        <rdfs:label xml:lang="es">Templo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Theme -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Theme">
        <rdfs:comment xml:lang="en">A travel theme that characterises the style of a trip (adventure, culture, wellness, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="es">Tema de viaje que caracteriza el estilo de un viaje (aventura, cultura, bienestar, etc.).</rdfs:comment>
        <rdfs:label xml:lang="es">Tema</rdfs:label>
        <rdfs:label xml:lang="en">Theme</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TouristAttraction -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TouristAttraction">
        <rdfs:comment xml:lang="es">Lugares, sitios o eventos de interés visitados por turistas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Places, sites or events of interest visited by tourists.</rdfs:comment>
        <rdfs:label xml:lang="es">Atracción Turística</rdfs:label>
        <rdfs:label xml:lang="en">Tourist Attraction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Tourists -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Tourists">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Group"/>
        <rdfs:comment xml:lang="es">Visitantes que viajan por ocio o cultura.</rdfs:comment>
        <rdfs:comment xml:lang="en">Visitors travelling for leisure or culture.</rdfs:comment>
        <rdfs:label xml:lang="en">Tourists</rdfs:label>
        <rdfs:label xml:lang="es">Turistas</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalDance -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalDance">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CulturalAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalHouse"/>
        <rdfs:comment xml:lang="en">A regional dance form expressing local culture.</rdfs:comment>
        <rdfs:comment xml:lang="es">Forma de baile regional que expresa la cultura local.</rdfs:comment>
        <rdfs:label xml:lang="es">Baile Tradicional</rdfs:label>
        <rdfs:label xml:lang="en">Traditional Dance</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalHouse -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalHouse">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CulturalAttraction"/>
        <rdfs:comment xml:lang="es">Arquitectura vernácula que representa las tradiciones constructivas locales.</rdfs:comment>
        <rdfs:comment xml:lang="en">Vernacular architecture representing local building traditions.</rdfs:comment>
        <rdfs:label xml:lang="es">Casa Tradicional</rdfs:label>
        <rdfs:label xml:lang="en">Traditional House</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalMarket -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TraditionalMarket">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Establishments"/>
        <rdfs:comment xml:lang="en">A local open-air market selling food, crafts, or goods.</rdfs:comment>
        <rdfs:comment xml:lang="es">Mercado local al aire libre que vende alimentos, artesanías o productos.</rdfs:comment>
        <rdfs:label xml:lang="es">Mercado Tradicional</rdfs:label>
        <rdfs:label xml:lang="en">Traditional Market</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Transportation -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Transportation">
        <rdfs:comment xml:lang="en">Means by which people travel to and within destinations.</rdfs:comment>
        <rdfs:comment xml:lang="es">Medios por los que las personas viajan a y dentro de los destinos.</rdfs:comment>
        <rdfs:label xml:lang="en">Transportation</rdfs:label>
        <rdfs:label xml:lang="es">Transporte</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TypicalFood -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TypicalFood">
        <rdfs:comment xml:lang="es">Platos tradicionales regionales típicos de un lugar.</rdfs:comment>
        <rdfs:comment xml:lang="en">Regional traditional dishes typical of a place.</rdfs:comment>
        <rdfs:label xml:lang="es">Comida Típica</rdfs:label>
        <rdfs:label xml:lang="en">Typical Food</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Villa -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Villa">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Accommodation"/>
        <rdfs:comment xml:lang="en">A private rental property, often a standalone house.</rdfs:comment>
        <rdfs:comment xml:lang="es">Propiedad privada de alquiler, frecuentemente una casa independiente.</rdfs:comment>
        <rdfs:label xml:lang="en">Villa</rdfs:label>
        <rdfs:label xml:lang="es">Villa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Volcano -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Volcano">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#NaturalAttractions"/>
        <rdfs:comment xml:lang="en">A natural volcanic mountain, often a hiking or sightseeing destination.</rdfs:comment>
        <rdfs:comment xml:lang="es">Montaña volcánica natural, frecuentemente destino de senderismo o turismo.</rdfs:comment>
        <rdfs:label xml:lang="en">Volcano</rdfs:label>
        <rdfs:label xml:lang="es">Volcán</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterSport -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterSport">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Activities"/>
        <rdfs:comment xml:lang="es">Actividades recreativas acuáticas (surf, snorkel, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">Aquatic recreational activities (surfing, snorkeling, etc.).</rdfs:comment>
        <rdfs:label xml:lang="es">Deporte de agua</rdfs:label>
        <rdfs:label xml:lang="en">Water Sport</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterTransport -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterTransport">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Transportation"/>
        <rdfs:comment xml:lang="en">Transport by water (ferries, ports, boats).</rdfs:comment>
        <rdfs:comment xml:lang="es">Transporte por agua (ferries, puertos, barcos).</rdfs:comment>
        <rdfs:label xml:lang="es">Transporte Marítimo</rdfs:label>
        <rdfs:label xml:lang="en">WaterTransport</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Woman -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Woman">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Adult"/>
        <rdfs:comment xml:lang="en">An adult female person.</rdfs:comment>
        <rdfs:comment xml:lang="es">Persona adulta de género femenino.</rdfs:comment>
        <rdfs:label xml:lang="es">Mujer</rdfs:label>
        <rdfs:label xml:lang="en">Woman</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Youth -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Youth">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Person"/>
        <rdfs:comment xml:lang="en">A young person, typically a teenager.</rdfs:comment>
