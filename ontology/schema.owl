        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#WaterTransport"/>
        <rdfs:comment xml:lang="en">Transport by aircraft (airports, airlines).</rdfs:comment>
        <rdfs:comment xml:lang="es">Transporte mediante aeronaves (aeropuertos, aerolíneas).</rdfs:comment>
        <rdfs:label xml:lang="en">AirTransport</rdfs:label>
        <rdfs:label xml:lang="es">TransporteAéreo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Allergens -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Allergens">
        <rdfs:comment xml:lang="en">A grouping class for known food allergens.</rdfs:comment>
        <rdfs:comment xml:lang="es">Clase agrupadora de alérgenos alimentarios conocidos.</rdfs:comment>
        <rdfs:label xml:lang="en">Allergens</rdfs:label>
        <rdfs:label xml:lang="es">Alérgenos</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Bar -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Bar">
