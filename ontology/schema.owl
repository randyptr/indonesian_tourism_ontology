<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/indonesian_tourism_ontology#"
     xml:base="http://www.semanticweb.org/indonesian_tourism_ontology"
     xmlns:ito="http://www.semanticweb.org/indonesian_tourism_ontology#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology">
        <owl:imports rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology/establishments"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology/food"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#availableAt -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#availableAt">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Establishments"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Location"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#connectsTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#connectsTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Transportation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
        <rdfs:comment xml:lang="en">Links a ferry service to the cities it connects (origin and destination).</rdfs:comment>
        <rdfs:label xml:lang="en">connectsTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasAccommodation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasAccommodation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasActivity -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasActivity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Activities"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasEstablishment -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasEstablishment">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Establishments"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasFood -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasFood">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Food"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasIngredient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasIngredient">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Ingredient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasTheme -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasTheme">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Activities"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Festival"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Museum"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Theme"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasTouristAttraction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasTouristAttraction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasTransportation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasTransportation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Transportation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#isAccessibleBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#isAccessibleBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Transportation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#locatedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#locatedIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#locatedInCity -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#locatedInCity">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#locatedIn"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Establishments"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Events"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Transportation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#locatedInCountry -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#locatedInCountry">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#locatedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Province"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Country"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#locatedInIsland -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#locatedInIsland">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#locatedIn"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#NaturalAttractions"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Island"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#locatedInProvince -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#locatedInProvince">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#locatedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Island"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Province"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#nearbyAccommodation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#nearbyAccommodation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#originatesFrom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#originatesFrom">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Province"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#servesFood -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#servesFood">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Establishments"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#establishedYear -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#establishedYear">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Park"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasAreaSqKm -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasAreaSqKm">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Country"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Island"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#NaturalAttractions"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Province"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.0</xsd:minInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasContactWebSite -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasContactWebSite">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasEndDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasEndDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Events"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasEntryFee -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasEntryFee">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasGlutenFreeFood -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasGlutenFreeFood">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Establishments"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasLactoseFreeFood -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasLactoseFreeFood">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Establishments"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasMaxCapacity -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasMaxCapacity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasMinimumAge -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasMinimumAge">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Activities"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Events"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</xsd:minInclusive>
                    </rdf:Description>
                    <rdf:Description>
                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">120</xsd:maxInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasName">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasOperatingHours -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasOperatingHours">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasPrice -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasPrice">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasRating -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasRating">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.0</xsd:minInclusive>
                    </rdf:Description>
                    <rdf:Description>
                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5.0</xsd:maxInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasReview -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasReview">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasStartDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasStartDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Events"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasTicket -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasTicket">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#hasVegetarianFood -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#hasVegetarianFood">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Establishments"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#isGlutenFree -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#isGlutenFree">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#isHalal -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#isHalal">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#isLactoseFree -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#isLactoseFree">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#isVegan -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#isVegan">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#isVegetarian -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#isVegetarian">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#isWheelchairAccessible -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#isWheelchairAccessible">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Transportation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#numberOfVisitors -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#numberOfVisitors">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</xsd:minInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#suitableFor -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#suitableFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Describes the type of visitor this attraction is suitable for (e.g., families, solo travellers, adventurers).</rdfs:comment>
        <rdfs:label xml:lang="en">suitableFor</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://dbpedia.org/ontology/Hotel -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Hotel">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Hotel"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/Island -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Island">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Island"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Location"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/Museum -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Museum">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Museum"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#CulturalAttraction"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/bus -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/bus">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Bus"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#LandTransport"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Accommodation">
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:comment xml:lang="es">Diferentes lugares en los que quedarse durante las vacaciones en Indonesia</rdfs:comment>
        <rdfs:comment xml:lang="en">Different places to stay during holidays in Indonesia</rdfs:comment>
        <rdfs:label xml:lang="en">Accommodation</rdfs:label>
        <rdfs:label xml:lang="es">Alojamiento</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Activities -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Activities">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#CityLifeAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#CulturalAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Events"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#NaturalAttractions"/>
        <rdfs:comment xml:lang="es">Actividades que los turistas pueden realizar durante su viaje (deportes, turismo, tours culturales).</rdfs:comment>
        <rdfs:comment xml:lang="en">Things tourists can do during their trip (sports, sightseeing, cultural tours).</rdfs:comment>
        <rdfs:label xml:lang="es">Actividades</rdfs:label>
        <rdfs:label xml:lang="en">Activities</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Adult -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Adult">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Group"/>
        <rdfs:comment xml:lang="en">An adult visitor (18 years or older).</rdfs:comment>
        <rdfs:label xml:lang="en">Adult</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Adventure -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Adventure">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Theme"/>
        <rdfs:comment xml:lang="en">Outdoor and physical activities such as hiking, surfing, and diving.</rdfs:comment>
        <rdfs:label xml:lang="en">Adventure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#AirTransport -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#AirTransport">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Transportation"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#LandTransport"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#WaterTransport"/>
        <rdfs:comment xml:lang="en">Transport by aircraft (airports, airlines).</rdfs:comment>
        <rdfs:comment xml:lang="es">Transporte mediante aeronaves (aeropuertos, aerolíneas).</rdfs:comment>
        <rdfs:label xml:lang="en">AirTransport</rdfs:label>
        <rdfs:label xml:lang="es">TransporteAéreo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Allergens -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Allergens">
        <rdfs:comment xml:lang="en">A grouping class for known food allergens.</rdfs:comment>
        <rdfs:comment xml:lang="es">Clase agrupadora de alérgenos alimentarios conocidos.</rdfs:comment>
        <rdfs:label xml:lang="en">Allergens</rdfs:label>
        <rdfs:label xml:lang="es">Alérgenos</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Art -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Art">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Theme"/>
        <rdfs:comment xml:lang="en">Visual arts, performances, crafts, and creative expressions.</rdfs:comment>
        <rdfs:label xml:lang="en">Art</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Bar -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Bar">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#CityLifeAttraction"/>
        <rdfs:comment xml:lang="en">A venue primarily serving alcoholic drinks.</rdfs:comment>
        <rdfs:comment xml:lang="es">Local que sirve principalmente bebidas alcohólicas.</rdfs:comment>
        <rdfs:label xml:lang="en">Bar</rdfs:label>
        <rdfs:label xml:lang="es">Bar</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Beach -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Beach">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#NaturalAttractions"/>
        <rdfs:comment xml:lang="en">A coastal area along the sea or ocean suitable for tourism.</rdfs:comment>
        <rdfs:comment xml:lang="es">Zona costera junto al mar u océano adecuada para el turismo.</rdfs:comment>
        <rdfs:label xml:lang="en">Beach</rdfs:label>
        <rdfs:label xml:lang="es">Playa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Beverage -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Beverage">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:comment xml:lang="en">A drink, alcoholic or non-alcoholic.</rdfs:comment>
        <rdfs:comment xml:lang="es">Bebida, alcohólica o no alcohólica.</rdfs:comment>
        <rdfs:label xml:lang="es">Bebida</rdfs:label>
        <rdfs:label xml:lang="en">Beverage</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Bus -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Bus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#LandTransport"/>
        <rdfs:comment xml:lang="en">A road vehicle for passenger transport over fixed routes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vehículo terrestre para transporte de pasajeros en rutas fijas.</rdfs:comment>
        <rdfs:label xml:lang="en">Bus</rdfs:label>
        <rdfs:label xml:lang="es">Bus</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Camping -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Camping">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#MountainSport"/>
        <rdfs:comment xml:lang="es">Estancia nocturna al aire libre en tiendas o refugios.</rdfs:comment>
        <rdfs:comment xml:lang="en">Outdoor overnight stay in tents or shelters.</rdfs:comment>
        <rdfs:label xml:lang="en">Camping</rdfs:label>
        <rdfs:label xml:lang="es">Camping</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#City -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#City">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Location"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Country"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Island"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Province"/>
        <rdfs:comment xml:lang="en">An urban settlement; municipality or regency.</rdfs:comment>
        <rdfs:comment xml:lang="es">Asentamiento urbano; municipio o regencia.</rdfs:comment>
        <rdfs:label xml:lang="en">City</rdfs:label>
        <rdfs:label xml:lang="es">Ciudad</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#CityLifeAttraction -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#CityLifeAttraction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#CulturalAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#NaturalAttractions"/>
        <rdfs:comment xml:lang="es">Lugares de entretenimiento urbano como bares, discotecas, pubs y espectáculos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Urban entertainment venues such as bars, clubs, pubs, and shows.</rdfs:comment>
        <rdfs:label xml:lang="en">City Life Attraction</rdfs:label>
        <rdfs:label xml:lang="es">Vida nocturna</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Climbing -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Climbing">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#MountainSport"/>
        <rdfs:comment xml:lang="es">Escalar rocas, montañas o paredes por deporte.</rdfs:comment>
        <rdfs:comment xml:lang="en">Scaling rocks, mountains or walls for sport.</rdfs:comment>
        <rdfs:label xml:lang="en">Climbing</rdfs:label>
        <rdfs:label xml:lang="es">Escalada</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Club -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Club">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#CityLifeAttraction"/>
        <rdfs:comment xml:lang="en">A nightclub featuring music and dancing.</rdfs:comment>
        <rdfs:comment xml:lang="es">Discoteca con música y baile.</rdfs:comment>
        <rdfs:label xml:lang="en">Club</rdfs:label>
        <rdfs:label xml:lang="es">Discoteca</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Condiment -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Condiment">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:comment xml:lang="en">A sauce or seasoning used to flavour food.</rdfs:comment>
        <rdfs:comment xml:lang="es">Salsa o condimento usado para sazonar la comida.</rdfs:comment>
        <rdfs:label xml:lang="en">Condiment</rdfs:label>
        <rdfs:label xml:lang="es">Condimento</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Country -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Country">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Location"/>
        <rdfs:comment xml:lang="en">A sovereign nation.</rdfs:comment>
        <rdfs:comment xml:lang="es">Nación soberana.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
        <rdfs:label xml:lang="es">País</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#CulturalAttraction -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#CulturalAttraction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#NaturalAttractions"/>
        <rdfs:comment xml:lang="en">Sites of cultural or historical significance such as museums, temples, ceremonies.</rdfs:comment>
        <rdfs:comment xml:lang="es">Sitios de relevancia cultural o histórica como museos, templos o ceremonias.</rdfs:comment>
        <rdfs:label xml:lang="es">Atracción Cultural</rdfs:label>
        <rdfs:label xml:lang="en">Cultural Attraction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Dessert -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Dessert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TypicalFood"/>
        <rdfs:comment xml:lang="en">A sweet course eaten at the end of a meal.</rdfs:comment>
        <rdfs:comment xml:lang="es">Plato dulce que se toma al final de una comida.</rdfs:comment>
        <rdfs:label xml:lang="en">Dessert</rdfs:label>
        <rdfs:label xml:lang="es">Postre</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Diving -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Diving">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#WaterSport"/>
        <rdfs:comment xml:lang="es">Deporte de natación submarina, con o sin equipo de buceo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Underwater swimming sport, with or without scuba gear.</rdfs:comment>
        <rdfs:label xml:lang="es">Buceo</rdfs:label>
        <rdfs:label xml:lang="en">Diving</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Establishments -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Establishments">
        <rdfs:comment xml:lang="en">Commercial or public venues where services are offered (markets, restaurants, vendors).</rdfs:comment>
        <rdfs:comment xml:lang="es">Lugares comerciales o públicos donde se ofrecen servicios (mercados, restaurantes, vendedores).</rdfs:comment>
        <rdfs:label xml:lang="es">Establecimiento</rdfs:label>
        <rdfs:label xml:lang="en">Establishment</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Events -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Events">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#TouristAttraction"/>
        <rdfs:comment xml:lang="es">Acontecimientos programados como festivales, ceremonias o espectáculos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Scheduled occurrences such as festivals, ceremonies or shows.</rdfs:comment>
        <rdfs:label xml:lang="es">Eventos</rdfs:label>
        <rdfs:label xml:lang="en">Events</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Ferry -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Ferry">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#WaterTransport"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#connectsTo"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A boat carrying passengers and vehicles across water.</rdfs:comment>
        <rdfs:comment xml:lang="es">Embarcación que transporta pasajeros y vehículos por el agua.</rdfs:comment>
        <rdfs:label xml:lang="en">Ferry</rdfs:label>
        <rdfs:label xml:lang="es">Ferry</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/indonesian_tourism_ontology#Festival -->

    <owl:Class rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Festival">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#Events"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/indonesian_tourism_ontology#locatedIn"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#City"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/indonesian_tourism_ontology#Province"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A periodic public celebration, often cultural or religious.</rdfs:comment>
        <rdfs:comment xml:lang="es">Celebración pública periódica, frecuentemente cultural o religiosa.</rdfs:comment>
        <rdfs:label xml:lang="en">Festival</rdfs:label>
        <rdfs:label xml:lang="es">Festival</rdfs:label>
    </owl:Class>
    


