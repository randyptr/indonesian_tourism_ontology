    <owl:Class rdf:about="http://www.owl-ontologies.com/travel.owl#NationalPark">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Park"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Accommodation -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Accommodation">
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TouristAttraction"/>
        <rdfs:comment xml:lang="es">Diferentes lugares en los que quedarse durante las vacaciones en Indonesia</rdfs:comment>
        <rdfs:comment xml:lang="en">Different places to stay during holidays in Indonesia</rdfs:comment>
        <rdfs:label xml:lang="en">Accommodation</rdfs:label>
        <rdfs:label xml:lang="es">Alojamiento</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Activities -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Activities">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#TouristAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CityLifeAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#CulturalAttraction"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Events"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#NaturalAttractions"/>
        <rdfs:comment xml:lang="es">Actividades que los turistas pueden realizar durante su viaje (deportes, turismo, tours culturales).</rdfs:comment>
        <rdfs:comment xml:lang="en">Things tourists can do during their trip (sports, sightseeing, cultural tours).</rdfs:comment>
        <rdfs:label xml:lang="es">Actividades</rdfs:label>
        <rdfs:label xml:lang="en">Activities</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Adult -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Adult">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#Person"/>
        <rdfs:comment xml:lang="en">A person of legal adult age.</rdfs:comment>
        <rdfs:comment xml:lang="es">Persona en edad adulta legal.</rdfs:comment>
        <rdfs:label xml:lang="en">Adult</rdfs:label>
        <rdfs:label xml:lang="es">Adulto</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#AirTransport -->

    <owl:Class rdf:about="http://www.semanticweb.org/emmaa/ontologies/2026/3/untitled-ontology-9#AirTransport">
