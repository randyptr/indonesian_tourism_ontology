@prefix ex:   <http://www.semanticweb.org/indonesian_tourism_ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

<http://www.semanticweb.org/indonesian_tourism_ontology/food>
    a owl:Ontology .


# Create the hasAllergens OBJ Property

ex:hasAllergens a owl:ObjectProperty ;
    rdfs:domain ex:Ingredient ;
    rdfs:range ex:Allergens ;
    rdfs:label "hasAllergens" .

#1. POPULATING THE Allergens CLASS WITH INDIVIDUALS
ex:Crustaceans a ex:Allergens ;
    rdfs:label "Crustaceans" .

ex:Nuts a ex:Allergens ;
    rdfs:label "Nuts" .

ex:Fish a ex:Allergens ;
    rdfs:label "Fish" .

ex:Celery a ex:Allergens ;
    rdfs:label "Celery" .

ex:Eggs a ex:Allergens ;
    rdfs:label "Eggs" .

ex:Lactose a ex:Allergens ;
    rdfs:label "Lactose" .

ex:Lupin a ex:Allergens ;
    rdfs:label "Lupin" .

ex:Molluscs a ex:Allergens ;
    rdfs:label "Molluscs" .

ex:Sesame_Seeds a ex:Allergens ;
    rdfs:label "Sesame_seeds" .

ex:Soybeans a ex:Allergens ;
    rdfs:label "Soybeans" .

ex:Sulphites a ex:Allergens ;
    rdfs:label "Sulphites" .

ex:Gluten a ex:Allergens ;
    rdfs:label "Gluten" .

# 2. POPULATING THE INGREDIENT CLASS WITH INDIVIDUALS
ex:Pork a ex:Ingredient ;
    rdfs:label "Pork" ;
    ex:isVegan "false"^^xsd:boolean ;
    ex:isVegetarian "false"^^xsd:boolean ;
    ex:isLactoseFree "true"^^xsd:boolean .

ex:Shrimp_Paste a ex:Ingredient ;
    rdfs:label "Shrimp Paste" ;
