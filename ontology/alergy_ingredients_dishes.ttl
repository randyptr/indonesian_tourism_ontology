@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

<http://www.semanticweb.org/emmaa/ontologies/2026/3/alergy-ingredients-dishes>
    a owl:Ontology .

# ---------------------------------------------------------
# 1. POPULATING THE Allergens CLASS WITH INDIVIDUALS
# ---------------------------------------------------------
ex:Crustaceans a ex:Allergens ;
    rdfs:label "Crustaceans" .

ex:Nuts a ex:Allergens ;
    rdfs:label "Nuts" .

ex:Fish a ex:Allergens ;
    rdfs:label "Fish" .

ex:Celery a ex:Allergens ;
    rdfs:label "Celery" .

ex:Eggs a ex:Allergens ;
    rdfs:label "Eggs" .

ex:Lactose a ex:Allergens ;
    rdfs:label "Lactose" .

ex:Lupin a ex:Allergens ;
    rdfs:label "Lupin" .

ex:Molluscs a ex:Allergens ;
    rdfs:label "Molluscs" .

ex:Sesame_Seeds a ex:Allergens ;
    rdfs:label "Sesame_seeds" .

ex:Soybeans a ex:Allergens ;
    rdfs:label "Soybeans" .

ex:Sulphites a ex:Allergens ;
    rdfs:label "Sulphites" .

ex:Gluten a ex:Allergens ;
    rdfs:label "Gluten" .

# ---------------------------------------------------------
# 2. POPULATING THE INGREDIENT CLASS WITH INDIVIDUALS

# =========================================================
# 1. YOUR ORIGINAL INGREDIENTS (Updated with isLactoseFree)
# =========================================================

ex:Pork a ex:Ingredient ;
    rdfs:label "Pork" ;
    ex:isVegan "false"^^xsd:boolean ;
    ex:isVegetarian "false"^^xsd:boolean ;
    ex:isLactoseFree "true"^^xsd:boolean .

