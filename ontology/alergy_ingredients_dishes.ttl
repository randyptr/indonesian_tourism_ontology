# Adding Dishes

#Bali

ex:Gado_Gado a ex:MainDish ;
    rdfs:label "Gado Gado" ;
    ex:hasIngredient ex:Spinach,
                     ex:Cabbage,
                     ex:Potato,
                     ex:Tofu,
                     ex:Tempeh,
                     ex:Peanut,         
                     ex:Sweet_Soy_Sauce, 
                     ex:Garlic,
                     ex:Chili_Pepper ;
    ex:originatesFrom ex:Bali .

ex:Nasi_Goreng a ex:MainDish ;
    rdfs:label "Nasi Goreng" ;
    ex:hasIngredient ex:White_Rice,
                     ex:Chicken,        
                     ex:Egg,            
                     ex:Sweet_Soy_Sauce,
                     ex:Garlic,
                     ex:Onion ;
    ex:originatesFrom ex:Bali .


ex:Babi_Guling a ex:MainDish ;
    rdfs:label "Babi Guling" ;
    ex:hasIngredient ex:Pork, 
                     ex:Shrimp_Paste, 
                     ex:Candlenut ;
    ex:originatesFrom ex:Bali .

ex:Lawar a ex:SideDish ;
    rdfs:label "Lawar" ;
    ex:hasIngredient ex:Pork, 
                     ex:Grated_Coconut, 
                     ex:Shrimp_Paste ;
    ex:originatesFrom ex:Bali .

ex:Sate_Lilit a ex:MainDish ;
    rdfs:label "Sate Lilit" ;
    ex:hasIngredient ex:Minced_Fish, 
                     ex:Grated_Coconut, 
                     ex:Candlenut ;
    ex:originatesFrom ex:Bali .

 
